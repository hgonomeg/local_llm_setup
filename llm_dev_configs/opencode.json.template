{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama (local)",
      "options": {
        "baseURL": "http://ollama_palace:11434/v1"
      },
      "models": {

      }
    }
  },
  "compaction": {
    "auto": true,
    "prune": true
  },
  "permission": {
    "bash": "ask"
  },
  "mcp": {
    "searxng": {
      "type": "local",
      "command": ["npx", "-y", "mcp-searxng"],
      "enabled": true,
      "environment": {
        "SEARXNG_URL": "http://searxng_llm:8080"
      }
    }
  }

}
