# =============================================================================
# Dockerfile.llm_dev — Arch Linux AI Development Workstation
#
# Full C/C++/Rust/Python/Node/LaTeX/Emscripten toolchain + OpenCode + web search
# Designed to be spawned as throwaway containers against an Ollama server.
# =============================================================================
FROM archlinux:base-devel

# ── Initialize pacman keyring and do full system upgrade ──────────────────
RUN pacman-key --init && \
    pacman-key --populate archlinux && \
    pacman -Syu --noconfirm

# ── Core system utilities ────────────────────────────────────────────────
RUN pacman -S --noconfirm --needed \
    sudo curl wget git openssh jq ripgrep fd bat eza tree less unzip zip \
    htop btop strace lsof inetutils iputils bind-tools \
    man-db man-pages

# ── Editors ──────────────────────────────────────────────────────────────
RUN pacman -S --noconfirm --needed \
    vim helix neovim

# ── C / C++ / Fortran toolchain ─────────────────────────────────────────
RUN pacman -S --noconfirm --needed \
    gcc clang lld lldb gdb \
    gcc-fortran \
    cmake meson ninja \
    pkg-config autoconf automake libtool \
    valgrind

# ── Rust ─────────────────────────────────────────────────────────────────
RUN pacman -S --noconfirm --needed \
    rustup && \
    rustup default stable && \
    rustup component add rust-analyzer

# ── Python ───────────────────────────────────────────────────────────────
RUN pacman -S --noconfirm --needed \
    python python-pip python-virtualenv python-pipx

# ── Node.js + TypeScript ─────────────────────────────────────────────────
RUN pacman -S --noconfirm --needed \
    nodejs npm typescript

# ── Emscripten ──────────────────────────────────────────────────────────
RUN pacman -S --noconfirm --needed \
    emscripten

# ── LaTeX (full installation via texlive) ────────────────────────────────
RUN pacman -S --noconfirm --needed \
    texlive-basic texlive-bin texlive-binextra \
    texlive-fontsrecommended texlive-fontsextra \
    texlive-latexrecommended texlive-latexextra \
    texlive-mathscience texlive-pictures \
    texlive-bibtexextra texlive-plaingeneric \
    biber

# ── ZSH stuff ────────────────────────────────
RUN pacman -S --noconfirm --needed zsh zsh-autosuggestions \
    zsh-history-substring-search zsh-syntax-highlighting \
    zsh-completions

# ── Bake default configs into /etc/skel
COPY llm_dev_configs/opencode.json.template /etc/skel/.config/opencode/opencode.json
COPY llm_dev_configs/zshrc        /etc/skel/.zshrc
COPY generate_opencode_config.sh /generate_opencode_config.sh
RUN chmod +x /generate_opencode_config.sh

RUN pacman -Scc --noconfirm
    
# ── Create non-root dev user with sudo ──────────────────────────────────
RUN useradd -m -s /bin/zsh -G wheel dev && \
    echo "dev ALL=(ALL) NOPASSWD: ALL" > /etc/sudoers.d/dev && \
    chmod 0440 /etc/sudoers.d/dev

RUN mkdir /workspace && chown dev:dev /workspace

# ── 10. Switch to dev user for remaining setup ─────────────────────────────
USER dev
WORKDIR /home/dev
ENV HOME=/home/dev

# ── Install non-root tools ───────────────────────────────────────────────────
RUN git clone https://aur.archlinux.org/yay.git && cd yay && makepkg -si --noconfirm && cd .. && rm -rf yay
RUN curl -fsSL https://opencode.ai/install | bash
## Also add Claude
RUN curl -fsSL https://claude.ai/install.sh | bash
ENV PATH="/home/dev/.opencode/bin:${PATH}"
RUN opencode plugin @tarquinen/opencode-dcp


WORKDIR /workspace

CMD ["/bin/zsh"]
